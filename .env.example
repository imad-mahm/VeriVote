APP_NAME=Verivote
APP_ENV=development
APP_URL=
APP_KEY=change-me
APP_TIMEZONE=UTC
SESSION_NAME=VERIVOTESESSID

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=verivote
DB_USER=root
DB_PASS=

NOTIFY_FROM_EMAIL=noreply@verivote.test

PHONE_DEFAULT_COUNTRY_CODE=961

SMS_ENABLED=0
SMS_PROVIDER=easy_sendsms
SMS_SENDER_ID=Verivote
SMS_FALLBACK_TO_EMAIL=1
SMS_RETRY_ATTEMPTS=3
SMS_RETRY_DELAY_MS=750
SMS_TIMEOUT_SECONDS=15

SMS_TEMPLATE_ACCOUNT_VERIFICATION="Verivote code: {code}. Expires in {minutes} min. [AR] Ramz tahaqoq Verivote: {code}. Saleh li muddat {minutes} daqiqa."
SMS_TEMPLATE_EVENT_VERIFICATION="Verification code for {event_title}: {code}. Expires in {minutes} min. [AR] Ramz tahaqoq li fa3aliat {event_title}: {code}. Saleh li muddat {minutes} daqiqa."
SMS_TEMPLATE_TOKEN_DELIVERY="Your voting token for {event_title}: {token}. Expires at {expires_at}. [AR] Ramz altaswit li fa3aliat {event_title}: {token}. Yantahi fi {expires_at}."

EASYSENDSMS_BASE_URL=https://restapi.easysendsms.app
EASYSENDSMS_SEND_PATH=/v1/rest/sms/send
EASYSENDSMS_AUTH_TYPE=apikey
EASYSENDSMS_TOKEN=
EASYSENDSMS_API_KEY=
EASYSENDSMS_API_SECRET=
EASYSENDSMS_SENDER_ID=

# Email (Gmail SMTP)
EMAIL_ENABLED=0
EMAIL_PROVIDER=gmail_smtp
EMAIL_RETRY_ATTEMPTS=2
EMAIL_RETRY_DELAY_MS=750
EMAIL_TIMEOUT_SECONDS=15

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=starttls
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Verivote
SMTP_REPLY_TO=
